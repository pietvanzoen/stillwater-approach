{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(make:*)",
      "Bash(luacheck:*)",
      "Bash(busted:*)",
      "Bash(stylua:*)",
      "Bash(luarocks:*)",
      "Bash(pdc:*)",
      "Bash(open:*)",
      "Bash(jq:*)",
      "Bash($PLAYDATE_SDK_PATH/bin/Playdate Simulator.app/Contents/MacOS/Playdate Simulator:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/log-usage.sh"
          }
        ]
      }
    ]
  }
}
